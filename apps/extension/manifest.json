{
  "manifest_version": 3,
  "name": "onda",
  "version": "0.1.0",
  "description": "Detect what you're listening to. Send gifts directly to artists.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://soundcloud.com/*",
    "https://*.bandcamp.com/*",
    "https://music.youtube.com/*",
    "https://app.subcult.music/*",
    "http://localhost:3000/*",
    "https://onda-tau.vercel.app/*",
    "https://onda.eth.pm/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://open.spotify.com/*"
      ],
      "js": [
        "content/spotify.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://soundcloud.com/*"
      ],
      "js": [
        "content/soundcloud.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.bandcamp.com/*"
      ],
      "js": [
        "content/bandcamp.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "content/youtube-music.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.subcult.music/*"
      ],
      "js": [
        "content/subcult.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*"
      ],
      "js": [
        "content/onda-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://onda-tau.vercel.app/*"
      ],
      "js": [
        "content/onda-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://onda.eth.pm/*"
      ],
      "js": [
        "content/onda-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
